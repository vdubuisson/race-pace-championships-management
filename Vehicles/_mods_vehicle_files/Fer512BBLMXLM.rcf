<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="8" />
		<INPUT NAME="TIRE" OPTIONS="4" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		
		<NAME LIVERY="51" NAME="Ch. Pozzi - JMS Racing #75" />
		
		<NAME LIVERY="52" NAME="N.A.R.T #64" />
		<NAME LIVERY="53" NAME="Ch. Pozzi Ferrari France #71" />
		<NAME LIVERY="54" NAME="Ch. Pozzi JMS Racing #62" />		
				
		<NAME LIVERY="55" NAME="EMKA Racing #78" />
		<NAME LIVERY="56" NAME="Scuderia Super Car Bellancauto #79" />
		
		
		<NAME LIVERY="57" NAME="N.A.R.T. #68" />
		<NAME LIVERY="58" NAME="Simmon Phillips #48" />
		<NAME LIVERY="99" NAME="Custom Livery" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	
	<CONDITION LIVERY="51">
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint" NEWMATERIAL="Vehicles\_Generic_Materials\livery_gt40_04_Y.mtx" />
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint_skin" NEWMATERIAL="Vehicles\_Generic_Materials\livery_gt40_04_autoskin_Y.mtx" />
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint_cpit" NEWMATERIAL="Vehicles\_Generic_Materials\livery_gt40_04_autocpit_Y.mtx" />
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint_cpit_skin" NEWMATERIAL="Vehicles\_Generic_Materials\livery_gt40_04_autoskin_autocpit_Y.mtx" />
		<REPLACE TEXTURE="Vehicles\Textures\Liveries\FORD_GT40_MKIV_LIVERY04.dds" NEWTEXTURE="Vehicles\Textures\Liveries\ferrari_512bblm_livery03_hr.dds" />				
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_grille_blank_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_grille_512bb_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_grille_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_grille_512bb_spec.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_wheel2_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_wheel3_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_wheel2_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_wheel3_spec.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_wheel2_blur_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_wheel3_blur_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_wheel2_blur_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_wheel3_blur_spec.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bb_lm_banner.dds" NEWTEXTURE="vehicles\textures\liveries\ferrari_512bblm_banner03.dds" />
	</CONDITION>


	<CONDITION LIVERY="52">
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects_Y.mtx" />
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint_skin" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects_autoskin_Y.mtx" />
		<REPLACE MATERIAL="vehicles\ferrari_512bb_lm\fer_512bblm_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects_autocpit_Y.mtx" />
