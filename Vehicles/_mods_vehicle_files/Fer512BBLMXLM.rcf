		<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\ferrari_512bblm_livery06_hr.dds" />
		<REPLACE TEXTURE="vehicles\textures\common_paint_fresnel.dds" NEWTEXTURE="vehicles\textures\liveries\ferrari_512bblm_livery06_fresnel.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_grille_blank_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_grille_512bb_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bblm_grille_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_512bblm_grille_512bb_spec.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512bb_lm_banner.dds" NEWTEXTURE="vehicles\textures\liveries\ferrari_512bblm_banner06.dds" />
	</CONDITION>

