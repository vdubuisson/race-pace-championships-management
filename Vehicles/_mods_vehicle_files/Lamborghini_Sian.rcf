		<REPLACE TEXTURE="Vehicles\Textures\common_leather_dgrey_stitch_white_diff.dds" NEWTEXTURE="vehicles\textures\common_leather02_brown2_stitching2_white_diff.dds" />
		<REPLACE TEXTURE="Vehicles\Textures\common_leather_dgrey_stitch_grey_diff.dds" NEWTEXTURE="vehicles\textures\common_leather02_brown2_stitching2_brown_diff.dds" />	
