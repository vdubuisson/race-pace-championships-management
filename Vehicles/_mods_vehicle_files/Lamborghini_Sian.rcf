<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="16" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="1" NAME="Olive Matte Metallic" />
		<NAME LIVERY="2" NAME="Aqua Metallic" />
		<NAME LIVERY="3" NAME="Matte Black" />
		<NAME LIVERY="4" NAME="Grigio Estoque" />
		<NAME LIVERY="5" NAME="Rosso Mars" />
		<NAME LIVERY="6" NAME="Blu Herra" />
		<NAME LIVERY="7" NAME="Bianco Canopus" />
		<NAME LIVERY="8" NAME="Giallo Evros" />
		<NAME LIVERY="9" NAME="Verde Faunus" />
		<NAME LIVERY="10" NAME="Grigio Telesto" />
		<NAME LIVERY="71" NAME="Livery 1" />
		<NAME LIVERY="72" NAME="Livery 2" />
		<NAME LIVERY="73" NAME="Livery 3" />
		<NAME LIVERY="74" NAME="Livery 4" />
		<NAME LIVERY="75" NAME="Livery 5" />
		<NAME LIVERY="76" NAME="Livery 6" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="1">
		<REPLACE MATERIAL="vehicles\lamborghini_sian\lam_sian_paint" NEWMATERIAL="vehicles\_generic_materials\paint_lamborghini_sian_matte_green.mtx" />
		<REPLACE MATERIAL="vehicles\lamborghini_sian\lam_sian_paint_skin" NEWMATERIAL="vehicles\_generic_materials\paint_lamborghini_sian_matte_green_autoskin.mtx" />
		<REPLACE MATERIAL="vehicles\lamborghini_sian\lam_sian_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\paint_lamborghini_sian_matte_green_autocpit.mtx" />
		<REPLACE MATERIAL="vehicles\lamborghini_sian\lam_sian_paint_cpit_skin" NEWMATERIAL="vehicles\_generic_materials\paint_lamborghini_sian_matte_green_autoskin_autocpit.mtx" />
		<REPLACE TEXTURE="Vehicles\Textures\common_leather_dgrey_diff.dds" NEWTEXTURE="vehicles\textures\common_leather02_brown2_diff.dds" />	
		<REPLACE TEXTURE="Vehicles\Textures\lam_sian_interior_diff.dds" NEWTEXTURE="vehicles\textures\lam_sian_interior_brown_diff.dds" />
