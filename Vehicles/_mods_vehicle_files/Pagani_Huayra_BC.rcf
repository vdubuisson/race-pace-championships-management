<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="26" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">		
		<NAME LIVERY="1" NAME="White / Carbon 1" />
		<NAME LIVERY="2" NAME="Matte Grey Metallic / Carbon" />
		<NAME LIVERY="3" NAME="Carbon / Red" />
		<NAME LIVERY="4" NAME="Blue / Carbon" />
		<NAME LIVERY="5" NAME="Blue Metallic / Carbon" />
		<NAME LIVERY="6" NAME="Purple Metallic / Carbon" />
		<NAME LIVERY="7" NAME="White / Carbon 2" />
		<NAME LIVERY="8" NAME="Blue Carbon" />
		<NAME LIVERY="9" NAME="Silver Metallic / Carbon" />
		<NAME LIVERY="10" NAME="Red Carbon" />
		<NAME LIVERY="11" NAME="Yellow" />
		<NAME LIVERY="12" NAME="Light Blue Metallic" />
		<NAME LIVERY="13" NAME="Supreme Gold" />
		<NAME LIVERY="14" NAME="Dark Grey Carbon" />
		<NAME LIVERY="15" NAME="Bronzo Aymara" />
		<NAME LIVERY="16" NAME="Orange Metallic" />
		<NAME LIVERY="17" NAME="White / Red Carbon" />
		<NAME LIVERY="18" NAME="Red Italia" />
		<NAME LIVERY="19" NAME="DarkGreen Metallic" />
		<NAME LIVERY="20" NAME="Yellow Metallic" />
		<NAME LIVERY="71" NAME="Livery 1" />
		<NAME LIVERY="72" NAME="Livery 2" />
		<NAME LIVERY="73" NAME="Livery 3" />
		<NAME LIVERY="74" NAME="Livery 4" />
		<NAME LIVERY="75" NAME="Livery 5" />
		<NAME LIVERY="76" NAME="Livery 6" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="1">
