 	<REPLACE TEXTURE="vehicles\textures\ferrari_333sp_wheel_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_333sp_wheel_green_diff.dds" />
 	<REPLACE TEXTURE="vehicles\textures\ferrari_333sp_wheel_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_333sp_wheel_green_spec.dds" />
