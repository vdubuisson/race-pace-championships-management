 	<REPLACE TEXTURE="vehicles\textures\liveries\lotus_exige_livery_metallic_blue.dds" NEWTEXTURE="vehicles\textures\liveries\acura_nsx_01_rac01_livery03_hr.dds" />	
 	<REPLACE TEXTURE="vehicles\textures\common_paint_alpha.dds" NEWTEXTURE="Vehicles\Textures\liveries\acura_nsx_01_rac01_livery03.dds" />
