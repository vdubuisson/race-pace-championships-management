 	<REPLACE TEXTURE="vehicles\textures\ferrari_333sp_wheel_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_333sp_wheel_gold_diff.dds" />
 	<REPLACE TEXTURE="vehicles\textures\ferrari_333sp_wheel_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_333sp_wheel_gold_spec.dds" />
