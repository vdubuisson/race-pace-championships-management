	<CONDITION LIVERY="7">
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_kermit_green.mtx" />	
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT_skin" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_kermit_green.mtx" />
		<REPLACE TEXTURE="vehicles\textures\common_carbon05_brown_diff.dds" NEWTEXTURE="vehicles\textures\common_carbon05_silver_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\aston_martin_vantage_db9_ams\amr_vantage_gt4_evo_rim_diff.dds" NEWTEXTURE="vehicles\textures\aston_martin_vantage_db9_ams\amr_vantage_gt4_evo_rim_silver_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\aston_martin_vantage_db9_ams\amr_vantage_gt4_evo_rim_blur_diff.dds" NEWTEXTURE="vehicles\textures\aston_martin_vantage_db9_ams\amr_vantage_gt4_evo_rim_blur_silver_diff.dds" />	
	</CONDITION>
	
	<CONDITION LIVERY="8">
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_lightning_silver.mtx" />	
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT_skin" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_lightning_silver.mtx" />
		<REPLACE TEXTURE="vehicles\textures\common_carbon05_brown_diff.dds" NEWTEXTURE="vehicles\textures\common_carbon05_silver_diff.dds" />
	</CONDITION>
	
	<CONDITION LIVERY="9">
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_lunar_white.mtx" />	
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT_skin" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_lunar_white.mtx" />
		<!-- <REPLACE TEXTURE="vehicles\textures\common_alcantara_black_new_diff.dds" NEWTEXTURE="vehicles\textures\common_alcantara_grey_diff.dds" /> -->
		<REPLACE TEXTURE="vehicles\textures\aston_martin_vantage_db9_ams\amr_vantage_gt4_evo_rim_diff.dds" NEWTEXTURE="vehicles\textures\aston_martin_vantage_db9_ams\amr_vantage_gt4_evo_rim_silver_diff.dds" />
