	<CONDITION LIVERY="10">
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_magnetic_silver.mtx" />	
		<REPLACE MATERIAL="vehicles\aston_martin_vantage_db9_ams\AMR_VAN_DB9_AMS_PAINT_skin" NEWMATERIAL="vehicles\_generic_materials\paint_aston_vantage25_magnetic_silver.mtx" />
		<REPLACE TEXTURE="vehicles\textures\common_carbon05_brown_diff.dds" NEWTEXTURE="vehicles\textures\common_carbon05_silver_diff.dds" />
