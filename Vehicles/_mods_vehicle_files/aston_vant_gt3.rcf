<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="19" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />					
	</INPUTS>

	<NAMES INPUT ="LIVERY">
      <NAME LIVERY="50" NAME="ADAC 2012 Young Driver AMR #33" /> 
    	<NAME LIVERY="51" NAME="Blancpain 2012 GPR AMR #89" />
      <NAME LIVERY="52" NAME="Blancpain 2017 Oman Racing Team with TF Sport #97" />
      <NAME LIVERY="53" NAME="Blancpain 2018 R Motorsport #62" />
      <NAME LIVERY="54" NAME="Blancpain 2018 R Motorsport #72" />
      <NAME LIVERY="55" NAME="N24h 2012 Young Driver AMR #007" />
      <NAME LIVERY="56" NAME="N24h 2018 Aston Martin Racing #007" />
      <NAME LIVERY="57" NAME="BGT 2014 Beechdean M-Sports #1" />
      <NAME LIVERY="58" NAME="BGT 2015 Oman Racing #6" />
      <NAME LIVERY="59" NAME="BGT 2017 Macmillan #24" />
      <NAME LIVERY="60" NAME="BGT 2018 TF Sport #11" />
      <NAME LIVERY="61" NAME="BGT 2018 TF Sport #17" />
      <NAME LIVERY="62" NAME="BGT 2018 Jetstream Motorsport #47" />
      <NAME LIVERY="63" NAME="BGT 2018 Optimum Motorsport #75" />
      <NAME LIVERY="64" NAME="BGT 2018 Beechdean AMR #99" />
      <NAME LIVERY="65" NAME="Bath 12h 2015 Craft Bamboo #97" /> 
	    <NAME LIVERY="66" NAME="Bath 12h 2019 R-Swiss #62a" />
      <NAME LIVERY="67" NAME="Macau 2013 Craft Racing #97" />
      <NAME LIVERY="68" NAME="Macau 2015 Craft Bamboo #97" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>
	
	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>	

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->
  <CONDITION LIVERY="50">
    <REPLACE MATERIAL="vehicles\aston_martin_vantage_gt3\am_van_gt3_paint" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects.mtx" />
    <REPLACE MATERIAL="vehicles\aston_martin_vantage_gt3\am_van_gt3_paint_skin" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects_autoskin.mtx" />
    <REPLACE MATERIAL="vehicles\aston_martin_vantage_gt3\am_van_gt3_paint_carbon" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects.mtx" />
