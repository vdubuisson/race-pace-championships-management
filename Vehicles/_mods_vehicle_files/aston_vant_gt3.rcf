    <REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="Vehicles\Textures\CustomLiveries\Aston_Martin_Vantage_GT3\am_van_gt3_livery50.dds"/>
    <REPLACE TEXTURE="Vehicles\Textures\am_van_gt3_banner.dds" NEWTEXTURE="Vehicles\Textures\CustomLiveries\Aston_Martin_Vantage_GT3\am_van_gt3_banner50.dds"/>       
    <REPLACE TEXTURE="Vehicles\Textures\common_tire_diff_00.dds" NEWTEXTURE="Vehicles\Textures\tire_yokohama_diff_00.dds"/>
    <REPLACE TEXTURE="Vehicles\Textures\common_tire_diff_01.dds" NEWTEXTURE="Vehicles\Textures\tire_yokohama_diff_01.dds"/>
    <REPLACE TEXTURE="Vehicles\Textures\common_tire_norm_00.dds" NEWTEXTURE="Vehicles\Textures\tire_yokohama_norm_00.dds"/>
