<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="8" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="50" NAME="Team Bentley #7" />
		<NAME LIVERY="51" NAME="Team Bentley #8" />
		<NAME LIVERY="52" NAME="Team Bentley #9" />
		<NAME LIVERY="53" NAME="Team Bentley #10" />
		<NAME LIVERY="54" NAME="Team Bentley #11" />
		<NAME LIVERY="55" NAME="Team Bentley #12" />
		<NAME LIVERY="56" NAME="Team Bentley #14" />
		<NAME LIVERY="57" NAME="Team Bentley #15" />
	
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->
	
	<CONDITION LIVERY="50">
		<REPLACE MATERIAL="vehicles\bentley_speed_8\ben_speed8_paint" NEWMATERIAL="vehicles\_generic_materials\livery_bentley_speed8.mtx" />
		<REPLACE MATERIAL="vehicles\bentley_speed_8\ben_speed8_paint_skin" NEWMATERIAL="vehicles\_generic_materials\livery_bentley_speed8_autoskin.mtx" />
		<REPLACE MATERIAL="vehicles\bentley_speed_8\ben_speed8_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\livery_bentley_speed8_autocpit.mtx" />
		<REPLACE MATERIAL="vehicles\bentley_speed_8\ben_speed8_paint_cpit_skin" NEWMATERIAL="vehicles\_generic_materials\livery_bentley_speed8_autoskin_autocpit.mtx" />
		<REPLACE TEXTURE="vehicles\textures\liveries\bentley_speed8_livery01.dds" NEWTEXTURE="vehicles\textures\liveries\bentley_speed8_livery01_hr.dds" />
		<REPLACE TEXTURE="vehicles\textures\ben_speed8_banner_diff.dds" NEWTEXTURE="vehicles\textures\liveries\ben_speed8_banner01.dds" />
