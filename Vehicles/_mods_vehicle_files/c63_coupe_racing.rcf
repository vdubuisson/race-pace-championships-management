<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="20" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="71" NAME="Team ACT #41" />
		<NAME LIVERY="72" NAME="Team ACT #42" />
		<NAME LIVERY="73" NAME="Team Racetech #88" />
		<NAME LIVERY="74" NAME="Team Racetech #89" />
		<NAME LIVERY="75" NAME="Team HR #61" />
		<NAME LIVERY="76" NAME="Team HR #62" />
		<NAME LIVERY="77" NAME="Team Magnaflow #73" />
		<NAME LIVERY="78" NAME="Team Magnaflow #74" />
		<NAME LIVERY="79" NAME="Team CXC #112" />
		<NAME LIVERY="80" NAME="Team CXC #113" />
		<NAME LIVERY="81" NAME="Team Dinan #84" />
		<NAME LIVERY="82" NAME="Team Dinan #85" />
		<NAME LIVERY="83" NAME="Team Megan Racing #114" />
		<NAME LIVERY="84" NAME="Team Megan Racing #115" />
		<NAME LIVERY="85" NAME="Team Ohlins #200" />
		<NAME LIVERY="86" NAME="Team Ohlins #201" />
		<NAME LIVERY="87" NAME="Team Superpro #164" />
		<NAME LIVERY="88" NAME="Team Superpro #165" />
		<NAME LIVERY="89" NAME="Team Brembo #130" />
		<NAME LIVERY="90" NAME="Team Brembo #131" />		
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->


	<CONDITION LIVERY="71">
		<REPLACE MATERIAL="vehicles\mercedes_c63_coupe_racing\merc_c63_cs_paint" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects.mtx" />
		<REPLACE MATERIAL="vehicles\mercedes_c63_coupe_racing\merc_c63_cs_paint_skin" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects_autoskin.mtx" />
		<REPLACE MATERIAL="vehicles\mercedes_c63_coupe_racing\merc_c63_cs_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\livery_generic_effects_autocpit.mtx" />
