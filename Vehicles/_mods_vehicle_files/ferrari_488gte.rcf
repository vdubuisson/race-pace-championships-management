	<CONDITION LIVERY="54">
	    <REPLACE MATERIAL="vehicles\ferrari_488_gte\fer_488_gt3_paint" NEWMATERIAL="vehicles\_generic_materials\livery_matte_black_metallic488.mtx" />
		<REPLACE MATERIAL="vehicles\ferrari_488_gte\fer_488_gt3_paint_skin" NEWMATERIAL="Vehicles\_Generic_Materials\livery_matte_black_metallic488_autoskin.mtx" />
