		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tread_dunlop_vintage_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tread_dunlop_vintage_diff.dds" />
