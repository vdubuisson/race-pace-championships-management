<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="8" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="51" NAME="S.E.F.A.C. Ferrari  #5" />
		<NAME LIVERY="52" NAME="S.E.F.A.C. Ferrari  #6" />
		<NAME LIVERY="53" NAME="S.E.F.A.C. Ferrari  #7" />
		<NAME LIVERY="54" NAME="S.E.F.A.C. Ferrari  #8" />
		<NAME LIVERY="55" NAME="North American Racing Team  #11" />
		<NAME LIVERY="56" NAME="Ecurie Francorchamps #12" />
		<NAME LIVERY="57" NAME="Scuderia Filipinetti #14" />
		<NAME LIVERY="58" NAME="Scuderia Filipinetti #15" />
		<NAME LIVERY="99" NAME="Custom Livery" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="51">
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\ferrari_512s\fer_512s_70_livery01_HR.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tire_goodyear_lm71_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tire_firestone_lm67_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tire_goodyear_lm71_blur_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tire_firestone_lm67_blur_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tire_goodyear_lm71_nmp8888.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tire_firestone_lm67_nmp8888.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tire_goodyear_lm71_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tire_firestone_lm67_spec.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tire_goodyear_lm71_blur_spec.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tire_firestone_lm67_blur_spec.dds" />
	</CONDITION>

	<CONDITION LIVERY="52">
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\ferrari_512s\fer_512s_70_livery02_HR.dds" />
		<REPLACE TEXTURE="vehicles\textures\ferrari_512s_cl\tire_goodyear_lm71_diff.dds" NEWTEXTURE="vehicles\textures\ferrari_512s_cl\tire_firestone_lm67_diff.dds" />
