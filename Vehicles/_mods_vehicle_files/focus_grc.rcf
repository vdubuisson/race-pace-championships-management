		<REPLACE TEXTURE="Vehicles\Textures\ford_focus_rx_wheel_blur_diff.dds" NEWTEXTURE="Vehicles\Textures\ford_focus_rx_wheel_blue2_blur_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\ford_focus_rx_banner_diff.dds" NEWTEXTURE="Vehicles\Textures\liveries\ford_focus_rx_banner_diff1.dds" />
