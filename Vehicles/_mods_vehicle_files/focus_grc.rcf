<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="19" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="51" NAME="Hoonigan Racing #13" />
		<NAME LIVERY="52" NAME="Sheriftizer RX Team #43" />
		<NAME LIVERY="53" NAME="Sheriftizer RX Team #44" />
		<NAME LIVERY="54" NAME="Sheriftizer RX Team #45" />
		<NAME LIVERY="55" NAME="Team Viljoen Logistics #77" />
		<NAME LIVERY="56" NAME="Team Viljoen Logistics #78" />
		<NAME LIVERY="57" NAME="EDGE Composites Racing #14" />
		<NAME LIVERY="58" NAME="EDGE Composites Racing #15" />
		<NAME LIVERY="59" NAME="Burnsprings Rally Team #66" />
		<NAME LIVERY="60" NAME="Burnsprings Rally Team #67" />
		<NAME LIVERY="61" NAME="Zavima Motorsport #24" />
		<NAME LIVERY="62" NAME="Zavima Motorsport #25" />
		<NAME LIVERY="63" NAME="Copter2 Racing Team #57" />
		<NAME LIVERY="64" NAME="Copter2 Racing Team #58" />
		<NAME LIVERY="65" NAME="Copter2 Racing Team #59" />
		<NAME LIVERY="66" NAME="Equipe JFB #92" />
		<NAME LIVERY="67" NAME="Equipe JFB #93" />
		<NAME LIVERY="68" NAME="Team Convroo #98" />
		<NAME LIVERY="69" NAME="Team Convroo #99" />
	
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="51">
		<REPLACE MATERIAL="Vehicles\Ford_Focus_GRC\ford_focus_rx_paint" NEWMATERIAL="Vehicles\_Generic_Materials\livery_generic_effects.mtx" />
		<REPLACE MATERIAL="Vehicles\Ford_Focus_GRC\ford_focus_rx_paint_skin" NEWMATERIAL="Vehicles\_Generic_Materials\livery_generic_effects_autoskin.mtx" />
