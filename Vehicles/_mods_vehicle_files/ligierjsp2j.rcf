		<REPLACE TEXTURE="vehicles\textures\common_tire_blur_spec.dds" NEWTEXTURE="Vehicles\Textures\tire_dunlop_lmp2_spec_00.dds" />
		<REPLACE TEXTURE="vehicles\textures\common_tire_nmp8888.dds" NEWTEXTURE="Vehicles\Textures\tire_dunlop_lmp2_nmp8888.dds" />
		<REPLACE TEXTURE="vehicles\textures\ligier_jsp2_banner_diff.dds" NEWTEXTURE="vehicles\textures\liveries\ligier_jsp2_banner01.dds" />
	</CONDITION>

