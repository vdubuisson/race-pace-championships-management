<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="20" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="51" NAME="Eltissen Motorsport #01" />
		<NAME LIVERY="52" NAME="Eltissen Motorsport #02" />
		<NAME LIVERY="53" NAME="Jameskett Racing #16" />
		<NAME LIVERY="54" NAME="Jameskett Racing #17" />
		<NAME LIVERY="55" NAME="DUKA Motor Racing #36" />
		<NAME LIVERY="56" NAME="DUKA Motor Racing #37" />
		<NAME LIVERY="57" NAME="Jennkins Rallycross #46" />
		<NAME LIVERY="58" NAME="Jennkins Rallycross #47" />		
		<NAME LIVERY="59" NAME="Team Britgens RX #33" />
		<NAME LIVERY="60" NAME="Team Britgens RX #34" />
		<NAME LIVERY="61" NAME="Almynec Racing #55" />
		<NAME LIVERY="62" NAME="Almynec Racing #56" />
		<NAME LIVERY="63" NAME="BNS Birdia Team #42" />
		<NAME LIVERY="64" NAME="BNS Birdia Team #43" />
		<NAME LIVERY="65" NAME="ROTMEG Racing Team #71" />
		<NAME LIVERY="66" NAME="ROTMEG Racing Team #72" />
		<NAME LIVERY="67" NAME="Togussi Motorsport #58" />
		<NAME LIVERY="68" NAME="Togussi Motorsport #59" />
		<NAME LIVERY="69" NAME="Nascalett Racing #27" />
		<NAME LIVERY="70" NAME="Nascalett Racing #28" />
		
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="51">
		<REPLACE MATERIAL="Vehicles\Mercedes_A45_RX\mercedes_a45_rx_paint" NEWMATERIAL="vehicles\_generic_materials\livery_fb_15.mtx" />
		<REPLACE MATERIAL="Vehicles\Mercedes_A45_RX\mercedes_a45_rx_paint_skin" NEWMATERIAL="Vehicles\_Generic_Materials\livery_fb_15_autoskin.mtx" />
