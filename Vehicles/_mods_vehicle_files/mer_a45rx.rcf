		<REPLACE TEXTURE="vehicles\textures\Liveries\FORMULA_B_LIVERY15.dds"  NEWTEXTURE="vehicles\textures\liveries\mercedes_a45_rx_livery01_hr.dds" />				
		<REPLACE TEXTURE="Vehicles\Textures\merc_a45_rx_wheel_diff.dds" NEWTEXTURE="Vehicles\Textures\merc_a45_rx_wheel_black_diff.dds" />
