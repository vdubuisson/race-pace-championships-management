		<REPLACE TEXTURE="vehicles\textures\nis_gtr_r32_wheel_blur_diff.dds" NEWTEXTURE="vehicles\textures\nis_gtr_r32_wheel2_blur_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\nis_gtr_r32_wheel_blur_spec.dds" NEWTEXTURE="vehicles\textures\nis_gtr_r32_wheel2_blur_spec.dds" />	
		<REPLACE TEXTURE="vehicles\textures\common_tire_diff.dds" NEWTEXTURE="vehicles\textures\tire_yokohama_gt_diff.dds" />
