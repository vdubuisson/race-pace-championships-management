<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="6" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="56" NAME="JTCC 1991 - Napolex Racing Team #12" />
		<NAME LIVERY="54" NAME="24H Spa 1991 - Nissan Team Zexel #25" />
		<NAME LIVERY="52" NAME="JTCC 1992 - Team Taisan #2" />
		<NAME LIVERY="55" NAME="JTCC 1992 - Team Kyoseki GP1 Plus #55" />
		<NAME LIVERY="51" NAME="JTCC 1993 - HKS Racing #87" />
		<NAME LIVERY="53" NAME="JTCC 1994 - Hoshino Impul Racing #1" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="51">
		<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\nissan_skyline_r32_groupa_livery01_hr.dds" />
		<REPLACE TEXTURE="vehicles\textures\nis_gtr_r32_misc_diff.dds" NEWTEXTURE="vehicles\textures\nis_gtr_r32_misc2_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\nis_gtr_r32_lights_diff.dds" NEWTEXTURE="vehicles\textures\nis_gtr_r32_lights2_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\nis_gtr_r32_lights_spec.dds" NEWTEXTURE="vehicles\textures\nis_gtr_r32_lights2_spec.dds" />		
		<REPLACE TEXTURE="vehicles\textures\nis_gtr_r32_badges_diff.dds" NEWTEXTURE="vehicles\textures\nis_gtr_r32_banner01.dds" />
