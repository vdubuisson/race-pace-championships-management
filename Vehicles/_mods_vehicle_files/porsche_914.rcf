	<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\PORSCHE_914_LIVERY08.dds" />
	</CONDITION>

	<CONDITION LIVERY="59">
	<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\PORSCHE_914_LIVERY09.dds" />
	</CONDITION>

	

	<CONDITION LIVERY="60">
		<REPLACE MATERIAL="vehicles\porsche_914\porsche_914_paint" NEWMATERIAL="vehicles\_generic_materials\livery_r500X_18914.mtx" />
		<REPLACE MATERIAL="vehicles\porsche_914\porsche_914_paint_skin" NEWMATERIAL="vehicles\_generic_materials\livery_r500X_18914_autoskin.mtx" />
		<REPLACE MATERIAL="vehicles\porsche_914\porsche_914_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\livery_r500X_18914_autocpit.mtx" />
		<REPLACE MATERIAL="vehicles\porsche_914\porsche_914_paint_cpit_skin" NEWMATERIAL="vehicles\_generic_materials\livery_r500X_18914_autoskin_autocpit.mtx" />

		<REPLACE TEXTURE="Vehicles\Textures\Liveries\CAT_X800_LIVERY18.dds" NEWTEXTURE="Vehicles\Textures\Liveries\PORSCHE_914_LIVERY10.dds" />
	</CONDITION>

	<CONDITION LIVERY="61">
	<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\PORSCHE_914_LIVERY11.dds" />
	</CONDITION>

	<CONDITION LIVERY="62">
	<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\PORSCHE_914_LIVERY12.dds" />
	</CONDITION>
	
	<CONDITION LIVERY="63">
	<REPLACE TEXTURE="vehicles\textures\common_paint.dds" NEWTEXTURE="vehicles\textures\liveries\PORSCHE_914_LIVERY13.dds" />

		<REPLACE TEXTURE="vehicles\textures\common_tire_vintage_diff.dds" NEWTEXTURE="vehicles\textures\dunlop914_diff_00.dds" />
		<REPLACE TEXTURE="vehicles\textures\common_tire_vintage_spec.dds" NEWTEXTURE="vehicles\textures\dunlop_diff_01.dds" />
		<REPLACE TEXTURE="vehicles\textures\common_tire_vintage_nmp8888.dds" NEWTEXTURE="vehicles\textures\tire_dunlop_basic_nmp8888.dds" />
		<REPLACE TEXTURE="vehicles\textures\common_tire_vintage_blur_diff.dds" NEWTEXTURE="vehicles\textures\tire_dunlop_basic_blur_diff.dds" />
		<REPLACE TEXTURE="vehicles\textures\common_tire_vintage_blur_spec.dds" NEWTEXTURE="vehicles\textures\tire_dunlop_basic_blur_spec.dds" />
