<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="17" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="1" NAME="Weiss" />
		<NAME LIVERY="2" NAME="Schwarz" />
		<NAME LIVERY="3" NAME="Carraraweiss Metallic" />
		<NAME LIVERY="4" NAME="Tiefschwarz Metallic" />
		<NAME LIVERY="5" NAME="Vulkangrau Metallic" />
		<NAME LIVERY="6" NAME="Cherrymetallic" />
		<NAME LIVERY="7" NAME="Dolomitesilber Metallic" />
		<NAME LIVERY="8" NAME="Frozenberry Metallic" />
		<NAME LIVERY="9" NAME="Coffeebeige Metallic" />
		<NAME LIVERY="10" NAME="Enzianblau Metallic" />
		<NAME LIVERY="11" NAME="Frozenblue Metallic" />
		<NAME LIVERY="12" NAME="Mambagrun Metallic" />
		<NAME LIVERY="13" NAME="Mahagoni Metallic" />
		<NAME LIVERY="14" NAME="Neptunblau" />
		<NAME LIVERY="15" NAME="Karminrot" />
		<NAME LIVERY="16" NAME="Kreid" />
		<NAME LIVERY="17" NAME="Eisgrau Metallic" />
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->

	<CONDITION LIVERY="1">
		<REPLACE MATERIAL="vehicles\porsche_taycan\por_taycan_paint" NEWMATERIAL="Modifications\Porsche taycan\paint\Weiss\por_taycan_paint.mtx" />
		<REPLACE MATERIAL="vehicles\porsche_taycan\por_taycan_paint_skin" NEWMATERIAL="Modifications\Porsche taycan\paint\Weiss\por_taycan_paint_skin.mtx" />
		<REPLACE MATERIAL="vehicles\porsche_taycan\por_taycan_paint_cpit" NEWMATERIAL="Modifications\Porsche taycan\paint\Weiss\por_taycan_paint_cpit.mtx" />
		<REPLACE MATERIAL="vehicles\porsche_taycan\por_taycan_paint_cpit_skin" NEWMATERIAL="Modifications\Porsche taycan\paint\Weiss\por_taycan_paint_cpit_skin.mtx" />	
	</CONDITION>

	<CONDITION LIVERY="2">
