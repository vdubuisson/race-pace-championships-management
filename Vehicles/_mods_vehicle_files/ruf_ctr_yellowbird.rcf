<?xml version="1.0" encoding="utf-8" ?>
<REPLACEMENT_SYSTEM>
	<!-- INPUTS section describes all inputs which can control selection of replacement items -->
	<INPUTS>
		<INPUT NAME="LIVERY" OPTIONS="25" />
		<INPUT NAME="TIRE" OPTIONS="6" />
		<INPUT NAME="DIRTTYPE" OPTIONS="3" />
	</INPUTS>

	<NAMES INPUT ="LIVERY">
		<NAME LIVERY="1" NAME="Yellow" />
		<NAME LIVERY="2" NAME="Bright Green" />
		<NAME LIVERY="3" NAME="White" />
		<NAME LIVERY="4" NAME="Black" />
		<NAME LIVERY="5" NAME="Silver Metallic" />
		<NAME LIVERY="6" NAME="Red" />
		<NAME LIVERY="7" NAME="Darkgreen Metallic" />
		<NAME LIVERY="51" NAME="Turquoise Metallic" />
		<NAME LIVERY="52" NAME="Yellow/Black Stripes" />
		<NAME LIVERY="53" NAME="Orange/Black Stripes" />
		<NAME LIVERY="54" NAME="Red/Wine Stripes" />
		<NAME LIVERY="55" NAME="Retro Style" />
		<NAME LIVERY="56" NAME="Dark Wood Motorsport" />
		<NAME LIVERY="57" NAME="Classic Stripes" />
		<NAME LIVERY="60" NAME="Dark Blue/Yellow Stripes" />
		<NAME LIVERY="61" NAME="Neon Green/Black Stripes" />
		<NAME LIVERY="62" NAME="Black/Yellow Stripes" />
		<NAME LIVERY="63" NAME="Green/Orange Stripes" />
		<NAME LIVERY="64" NAME="Blue Metallic" />
		<NAME LIVERY="65" NAME="Curtis Cams" />
		<NAME LIVERY="66" NAME="Racing Yellow" />
		<NAME LIVERY="67" NAME="Gold Metallic/Black Stripes" />
		<NAME LIVERY="68" NAME="Dark Blue/Red Stripes" />
		<NAME LIVERY="69" NAME="Bronze Metallic" />
		<NAME LIVERY="70" NAME="Light Blue Metallic" />		
	</NAMES>

	<NAMES INPUT ="TIRE">
		<NAME TIRE="1" NAME="Soft" />
		<NAME TIRE="2" NAME="Medium" />
		<NAME TIRE="3" NAME="Hard" />
		<NAME TIRE="4" NAME="Intermediate" />
		<NAME TIRE="5" NAME="Wet" />
		<NAME TIRE="6" NAME="Extreme" />
	</NAMES>

	<NAMES INPUT ="DIRTTYPE">
		<NAME DIRTTYPE="1" NAME="Dirt" />
		<NAME DIRTTYPE="2" NAME="Snow" />
		<NAME DIRTTYPE="3" NAME="Mud" />
	</NAMES>

	<!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations are permitted -->
	<!-- this will only be used in game for the menu system, and in the editor -->

	<!-- CONDITION sections define what to replace and when to replace it		-->
	<!-- They are used in the same way for all situations				-->
	
	<!-- Simple case - exterior paint effecting two materials -->
	
	
	<CONDITION LIVERY="1">
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_yellow.mtx" />
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint_skin" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_yellow_autoskin.mtx" />
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_yellow_autocpit.mtx" />
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint_cpit_skin" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_yellow_autoskin_autocpit.mtx" />
	</CONDITION>

	<CONDITION LIVERY="2">
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_brightgreen.mtx" />
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint_skin" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_brightgreen_autoskin.mtx" />
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint_cpit" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_brightgreen_autocpit.mtx" />
