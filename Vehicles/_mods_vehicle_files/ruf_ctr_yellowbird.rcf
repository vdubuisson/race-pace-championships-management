	</CONDITION>

	<CONDITION LIVERY="3">
		<REPLACE MATERIAL="vehicles\ruf_ctr_yellowbird\ruf_ctr_87_paint" NEWMATERIAL="vehicles\_generic_materials\paint_ruf_white.mtx" />
