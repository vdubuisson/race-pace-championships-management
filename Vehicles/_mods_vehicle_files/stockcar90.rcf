<?xml version="1.0" encoding="utf-8"?>
<REPLACEMENT_SYSTEM>
  <!-- INPUTS section describes all inputs which can control selection of replacement items -->
  <INPUTS>
    <INPUT NAME="LIVERY" OPTIONS="33" />
    <INPUT NAME="TIRE" OPTIONS="4" />
    <INPUT NAME="DIRTTYPE" OPTIONS="3" />
  </INPUTS>


  <NAMES INPUT="LIVERY">
    <NAME LIVERY="1" NAME="#1 Rick Mast - Skoal Classic" />
    <NAME LIVERY="2" NAME="#3 Dale Earnhardt - GM Goodwrench" />
    <NAME LIVERY="3" NAME="#4 Sterling Marlin - Kodak" />
    <NAME LIVERY="4" NAME="#5 Ricky Rudd - Levi Garrett" />
    <NAME LIVERY="5" NAME="#7 Alan Kulwicki - Zerex" />
    <NAME LIVERY="6" NAME="#9 Bill Elliott - Coors Melling" />
    <NAME LIVERY="7" NAME="#10 Derrike Cope - Purolator" />
    <NAME LIVERY="8" NAME="#15 Morgan Shepherd - Motorcraft" />
    <NAME LIVERY="9" NAME="#17 Darrell Waltrip - Tide" />
    <NAME LIVERY="10" NAME="#21 Dale Jarrett - Citgo" />
    <NAME LIVERY="11" NAME="#27 Rusty Wallace - Miller" />
    <NAME LIVERY="12" NAME="#33 Harry Gant - Skoal Bandit" />
    <NAME LIVERY="13" NAME="#24 Jeff Gordon - Dupont" />
    <NAME LIVERY="14" NAME="#7 Danica Patrick - Sonic" />
    <NAME LIVERY="15" NAME="#28 Ernie Irvan - Havoline" />
    <NAME LIVERY="16" NAME="#18 Kyle Busch - MnM" />
    <NAME LIVERY="17" NAME="#26 Brett Bodine - Quaker State" />
    <NAME LIVERY="18" NAME="#30 Michael Waltrip - Country Time" />
    <NAME LIVERY="19" NAME="#43 Richard Petty - STP" />
    <NAME LIVERY="20" NAME="#48 Jimmie Johnson - Lowe's Power of Pride" />
    <NAME LIVERY="21" NAME="#83 Lake Speed - Prestone" />
    <NAME LIVERY="22" NAME="#7 Alan Kulwicki - Hooters" />
    <NAME LIVERY="23" NAME="#25 Tim Richmond - Folgers" />
    <NAME LIVERY="24" NAME="#11 Geoff Bodine - Budweiser" />
    <NAME LIVERY="25" NAME="#6 Mark Martin - Valvoline" />
    <NAME LIVERY="26" NAME="#5 Terry Labonte - Kellogg's" />
    <NAME LIVERY="27" NAME="#9 Jerry Nadeau - Powerpuff Girls" />
    <NAME LIVERY="28" NAME="#42 Kyle Petty - Peak" />
    <NAME LIVERY="29" NAME="#19 Chad Little - Bull's Eye" />
    <NAME LIVERY="30" NAME="#25 Ken Schrader - kodiak" />
    <NAME LIVERY="31" NAME="#8 Hut Stricklin - circuit city" />
    <NAME LIVERY="32" NAME="#57 Jimmy Spencer - Hienz" />
    <NAME LIVERY="33" NAME="#66 Dick Trickle - Trop Artic" />

  </NAMES>

  <NAMES INPUT="TIRE">
    <NAME TIRE="1" NAME="Soft" />
    <NAME TIRE="4" NAME="Intermediate" />
    <NAME TIRE="5" NAME="Wet" />
    <NAME TIRE="6" NAME="Extreme" />
  </NAMES>

  <!-- DEPENDENCY section describes inputs which depend on each other in that only some combinations
  are permitted -->
  <!-- this will only be used in game for the menu system, and in the editor -->

  <!-- CONDITION sections define what to replace and when to replace it		-->
  <!-- They are used in the same way for all situations				-->

  <!-- Simple case - exterior paint effecting two materials -->

  <CONDITION LIVERY="1">
    <REPLACE TEXTURE="Vehicles\Textures\stock90_textures\stock90_texture_PAINT.dds"
      NEWTEXTURE="Vehicles\Textures\Liveries\stock90_1_hr.dds" />
