  <!-- Soft Slick tire -->
  <CONDITION TIRE="1">
    <REPLACE TEXTURE="vehicles\textures\stock90_textures\tread_slick1_diff.dds"
      NEWTEXTURE="vehicles\textures\stock90_textures\tread_slick1_diff.dds" />
    <REPLACE TEXTURE="vehicles\textures\stock90_textures\tread_slick1_blur_diff.dds"
      NEWTEXTURE="vehicles\textures\stock90_textures\tread_slick1_blur_diff.dds" />
    <REPLACE TEXTURE="vehicles\textures\stock90_textures\tread_slick1_nmp8888.dds"
      NEWTEXTURE="vehicles\textures\stock90_textures\tread_slick1_nmp8888.dds" />
    <REPLACE TEXTURE="vehicles\textures\stock90_textures\tread_slick1_blur_nmp8888.dds"
      NEWTEXTURE="vehicles\textures\stock90_textures\stock90_textures\tread_slick1_blur_nmp8888.dds" />
    <REPLACE TEXTURE="vehicles\textures\stock90_textures\tread_slick1_spec.dds"
      NEWTEXTURE="vehicles\textures\stock90_textures\tread_slick1_spec.dds" />
    <REPLACE TEXTURE="vehicles\textures\stock90_textures\tread_slick1_blur_spec.dds"
      NEWTEXTURE="vehicles\textures\stock90_textures\tread_slick1_blur_spec.dds" />
  </CONDITION>

  <!-- Medium Slick tire. In case AI uses it -->
  <CONDITION TIRE="2">
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_diff.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_diff.dds" />
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_blur_diff.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_blur_diff.dds" />
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_nmp8888.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_nmp8888.dds" />
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_blur_nmp8888.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_blur_nmp8888.dds" />
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_spec.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_spec.dds" />
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_blur_spec.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_blur_spec.dds" />
  </CONDITION>

  <!-- Hard Slick tire -->
  <CONDITION TIRE="3">
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_diff.dds"
      NEWTEXTURE="vehicles\textures\tread_slick1_diff.dds" />
    <REPLACE TEXTURE="vehicles\textures\tread_slick1_blur_diff.dds"
